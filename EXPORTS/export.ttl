<https://closingthegap.org/id/project/eaf36ccc-5ee4-4749-80ea-7f71f479c968> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2911298/hamburg.html> ;
