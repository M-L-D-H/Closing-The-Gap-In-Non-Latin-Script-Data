<https://closingthegap.org/id/project/46aff246-b6ef-4632-90c2-0993a9f9b1f5> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2950159/berlin.html> ;
            schema:name "Berlin" ] ;
    dcterms:created "2023-10-23"^^xsd:date ;
    dcterms:description "Arabic Literature Cosmopolitan and AnonymClassic jointly are the first ever comprehensive study of Kalila and Dimna, one of the most important text of premodern world literature which passed from Hinduism and Buddhism via Islam to Christianity. Its Arabic versions constitute a source of all further translations into European languages and are also the main focus of the project, which analyzes the transmission processes of the work from India to Europe with Arabic as cultural bridge."@en ;
    dcterms:identifier "46aff246-b6ef-4632-90c2-0993a9f9b1f5" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
