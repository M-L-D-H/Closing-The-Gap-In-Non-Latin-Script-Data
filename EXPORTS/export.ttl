<https://closingthegap.org/id/project/8682a8f5-b601-4a6c-808c-aa4b7ce8a7c4> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2879139/leipzig.html> ;
