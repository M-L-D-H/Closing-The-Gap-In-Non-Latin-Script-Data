<https://closingthegap.org/id/project/04ea57c8-69c7-4c83-8249-753850e9cc53> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/6553087/muenster.html> ;
            schema:name "Münster" ] ;
    dcterms:created "2021-11-01"^^xsd:date ;
    dcterms:description "Against the concept of the decline of Islamic cultures after the 11th century it becomes apparent that this period witnessed vast literal and cultural developments. One of these is a major impact of the most important poet of Mamluk era, Ibn Nubātah, on the Arabic literature for the centuries after him. The aim of this project is a complete digital edition of his diwan and twelve other works, most of with are available only in bad prints. Due to many revisions and rewritings made by the author the editing of his works is a great challenge. In order to represent his poetry correctly the edition will contain may versions of the poems enabling their comparison."@en ;
    dcterms:identifier "04ea57c8-69c7-4c83-8249-753850e9cc53" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Edition des Gesamtwerkes von Ibn Nubātah al-Miṣrī"@en ;
    schema:additionalProperty [ a schema:PropertyValue ;
