            schema:contributor <https://orcid.org/0009-0009-6369-4998> ;
            schema:roleName "supervision" ] ;
    schema:hostInstitution [ dcterms:isReferencedBy <https://ror.org/00pd74e08> ;
            schema:name "Westfälische Wilhelms-Universität Münster" ] ;
    schema:keywords "arabic_studies",
        "digital_edition",
        "digital_preservation",
        "lexicon",
        "literary_studies",
        "manuscript",
        "vre" ;
    schema:temporalCoverage [ schema:endDate "2032-01-01"^^xsd:date ;
            schema:startDate "2020-01-01"^^xsd:date ] ;
    schema:url <https://gepris.dfg.de/gepris/projekt/423723105>,
        <https://scdh.zivgitlabpages.uni-muenster.de/hees-alea/alea-hugo-website/>,
        <https://www.uni-muenster.de/ALEA/> ;
    ex:maintained true .

