<https://closingthegap.org/id/project/d5dd164d-1887-473f-8282-584b8d09474d> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2751773/leiden.html> ;
            schema:name "Leiden" ] ;
    dcterms:created "2023-10-31"^^xsd:date ;
    dcterms:description "This project aims to create a dynamic reconstruction of historical events that revolved around the conflict between Tang China and the Arab Caliphate around 750, ultimately establishing a balance of power between the two empires in Central Asia. The methodology employed is multidisciplinary, combining historical and archaeological data related to frontier dynamics and mobility. These data will be integrated into theoretical network analysis models and Geographic Information Systems (GIS)."@en ;
    dcterms:identifier "d5dd164d-1887-473f-8282-584b8d09474d" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
