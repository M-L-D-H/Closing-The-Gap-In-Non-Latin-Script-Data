<https://closingthegap.org/id/project/942e9692-8e2a-4060-84d8-c8db17eae689> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/293788/ramat-gan.html> ;
