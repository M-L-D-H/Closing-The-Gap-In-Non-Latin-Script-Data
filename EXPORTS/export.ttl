<https://closingthegap.org/id/project/17fa004d-c9d2-4ce3-8116-b7bfff5d14ed> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2911298/hamburg.html> ;
            schema:name "Hamburg" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/2952984/bamberg.html> ;
            schema:name "Bamberg" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/2918632/goettingen.html> ;
            schema:name "Göttingen" ] ;
    dcterms:created "2022-06-16"^^xsd:date ;
    dcterms:description "This project aims at documenting the endangered language and cultural practices of the Gorani speech community in western Iran. It will provide a collection of film recordings, highlighting the importance of musical performances in all areas of Gorani folklore and culture, annotated collections of religious texts, traditional folklore, oral narratives (mainly from recent history), and everyday speech, descriptive grammatical sketch of the Gawraju’i variety of Gorani and an electronic lexicon with multimedia applications."@en ;
    dcterms:hasPart <https://closingthegap.org/id/project/a8ee7d05-56b3-4312-8e1a-a07a46fdc809> ;
    dcterms:identifier "17fa004d-c9d2-4ce3-8116-b7bfff5d14ed" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/hac>,
        <http://id.loc.gov/vocabulary/iso639-2/kur> ;
    dcterms:title "Documentation of Gorani, an endangered language of West Iran"@en ;
