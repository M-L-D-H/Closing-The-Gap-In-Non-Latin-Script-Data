<https://closingthegap.org/id/project/7050ac6d-523c-4ba0-b381-48ec200ff6c4> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2950159/berlin.html> ;
            schema:name "Berlin" ] ;
    dcterms:created "2021-10-30"^^xsd:date ;
    dcterms:description "KALiMaT is the first bilingual, open-access Arabic-English online living handbook of short articles on historical terms from the pre-modern and early modern literary tradition. Each article addresses a lemma, providing analysis and contextualization that makes the historical term accessible. With its nuanced approach focused on the analysis of concepts from the Arabic tradition and the critical examination of Western and modern literary categories, as well as with its bilingual publication strategy in both English and Arabic, KALiMaT contributes to the decolonization of knowledge. The project will be hosted on the Open Encyclopedia System infrastructure offered by Freie Universität Berlin."@en ;
    dcterms:identifier "7050ac6d-523c-4ba0-b381-48ec200ff6c4" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Keywords for the Study of the Arabic Literary and Manuscript Tradition"@en ;
