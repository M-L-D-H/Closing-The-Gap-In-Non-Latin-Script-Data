<https://closingthegap.org/id/project/192ddf37-ff95-454d-beb1-919c8e71c6b8> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/5102922/> ;
            schema:name "Princeton" ] ;
    dcterms:created "2024-12-06"^^xsd:date ;
    dcterms:description "The project aims to advance digital humanities research by integrating eScriptorium handwritten text recognition (HTR) software into Princeton's research infrastructure. By making historical texts machine-readable, it enables text search and computational analysis at scale, lowering barriers of technical expertise and cost for humanities scholars. This pilot project explores creating a centralized resource for HTR to support diverse research workflows in the digital humanities."@en ;
    dcterms:identifier "192ddf37-ff95-454d-beb1-919c8e71c6b8" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
