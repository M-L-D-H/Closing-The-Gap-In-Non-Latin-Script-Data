<https://closingthegap.org/id/project/b0da2d75-183c-4fa4-8b12-47366c02ed7c> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2867714/munich.html> ;
