    dcterms:created "2025-04-16"^^xsd:date ;
    dcterms:description "This project investigates 76 medieval Islamic legal and administrative documents on paper produced in fourteenth-century Northwest Iran. The projects seeks to understand how these original documents were created by examining the relationship between written artefact and the parties involved in the production of these documents."@en ;
    dcterms:identifier "5d52a387-f88b-44d8-a79b-3225e5ca5030" ;
    dcterms:title "The Persian Documents from al-Ḥaram al-Sharīf in Jerusalem, 1300–1353"@en ;
