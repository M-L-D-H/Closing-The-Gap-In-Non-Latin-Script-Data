            schema:name "Darmstadt" ] ;
    dcterms:created "2024-07-12"^^xsd:date ;
    dcterms:description "The project combines New Testament textual criticism, analyses of the reception of gender constructions, information science research, and systematic-ethical investigations. The central aim of the project is to analyze how digitally supported research can provide interdisciplinary gender studies with new opportunities for analyzing the transmission of texts and uncovering associated understandings of gender."@en ;
    dcterms:identifier "1fb988de-a02c-42d9-951d-1d7de01b598c" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/deu>,
