<https://closingthegap.org/id/project/9d6d90d9-e8d4-44fa-ae1f-2206c453e4a7> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/3174530/lucca.html> ;
            schema:name "Lucca" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/3170647/pisa.html> ;
            schema:name "Pisa" ] ;
    dcterms:created "2025-03-01"^^xsd:date ;
    dcterms:description "The project aims to provide an accurate knowledge of the historical significance and doctrinal impact of the Ilahiyyat (Metaphysics) of Ibn Sina (Avicenna)’s Kitab al-Shifa' (Book of the Cure, or: of the Healing) – one of the masterpieces of Medieval Arabic philosophy in the Islamic world, and one of the most influential and widespread works of falsafa of all times – by means of a reconstruction of the manuscript tradition, a reliable edition, an English translation, and a doctrinal explanation of the text of the work."@en ;
    dcterms:identifier "9d6d90d9-e8d4-44fa-ae1f-2206c453e4a7" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Philosophy on the Border of Civilizations and Intellectual Endeavours: towards a Critical Edition of the Metaphysics (Ilāhiyyāt of Kitāb al-Šifāʾ) of Avicenna (Ibn Sīnā)"@en ;
    schema:additionalProperty [ a schema:PropertyValue ;
