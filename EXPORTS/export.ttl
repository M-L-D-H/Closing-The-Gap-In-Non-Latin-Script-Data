<https://closingthegap.org/id/project/6298a9cd-d41a-40d8-91d0-c532692e95c9> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2766823/salzburg.html> ;
            schema:name "Salzburg" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/2761369/vienna.html> ;
