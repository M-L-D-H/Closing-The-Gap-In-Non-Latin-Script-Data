<https://closingthegap.org/id/project/2253d7f2-c150-44e2-9a8a-c7c5ba0ab661> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2934246/duesseldorf.html> ;
