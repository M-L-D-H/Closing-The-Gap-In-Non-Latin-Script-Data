<https://closingthegap.org/id/project/d17ea973-8be6-4d5c-81e2-75c69e8e4e37> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2640729/oxford.html> ;
