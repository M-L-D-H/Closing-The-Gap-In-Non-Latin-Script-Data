            schema:name "Berlin" ] ;
    dcterms:created "2023-12-04"^^xsd:date ;
    dcterms:description "The Elephantine Manuscripts Project employs cutting-edge digital methodologies, integrating disciplines like digital humanities, physics, and mathematics. A central element is the development of an open-access online research database, housing 80% previously unpublished manuscripts in ten different languages and scripts. The database provides unprecedented insights into the medical, religious, legal, administrative, and literary aspects of Elephantine's history spanning 4000 years."@en ;
    dcterms:identifier "43faf354-6069-4d15-9e04-bcb5813bc67a" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
