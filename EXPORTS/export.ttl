    dcterms:created "2022-11-25"^^xsd:date ;
    dcterms:description "For scholars studying ḥadīth texts, drawing an isnād tree with more than 40 transmitters is a tedious task, and finding the right medium to display it fully can even prove to be impossible. isnalyser is a simple program for the automation of drawing isnād trees and for their customizable display in handy formats."@en ;
    dcterms:hasPart <https://closingthegap.org/id/project/2b2d72f0-c4d6-462b-b47f-7c3550acdad3> ;
    dcterms:identifier "da852d13-2483-443b-a2f3-77c0d19d08bd" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Isnalyser"@en ;
    schema:additionalProperty [ a schema:PropertyValue ;
            schema:propertyID "publications" ;
