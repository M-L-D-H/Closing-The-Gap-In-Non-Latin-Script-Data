<https://closingthegap.org/id/project/e050deba-6e1d-4d82-851b-cf6c1f7187a5> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2761369/vienna.html> ;
            schema:name "Vienna" ] ;
    dcterms:created "2022-05-10"^^xsd:date ;
    dcterms:description "The focus of this projects lies on Iranian and Central Asian societies in the period between the 13th and 15th century which witnessed nomadic conquest after the rise of Chinggis Khan. The process of transculturation and interaction between the sedentary Muslim conquered and nomadic conqueror is documented in largely unstudied manuscripts from that period, which will be explored and analyzed in the course of this project. The technical side of the project will be responsible for developing and implementing of an independent Analytical Database of Islamic Manuscripts which will serve both as a digital repository of manuscripts and an analytical tool that will allow users to do wider research on Islamic and Eurasian studies."@en ;
    dcterms:identifier "e050deba-6e1d-4d82-851b-cf6c1f7187a5" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
        <http://id.loc.gov/vocabulary/iso639-2/fas> ;
    dcterms:title "NoMansLand: Nomads’ Manuscripts Landscape"@en ;
