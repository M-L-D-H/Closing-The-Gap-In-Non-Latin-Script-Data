<https://closingthegap.org/id/project/ff1ec94f-2233-46e9-b550-45c792ae581e> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2766823/salzburg.html> ;
