<https://closingthegap.org/id/project/0cf58379-39c3-4e95-b7b1-cc9f7f11c7ba> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2988506/paris.html> ;
            schema:name "Paris" ] ;
    dcterms:created "2022-09-08"^^xsd:date ;
    dcterms:description "Scripta-PSL aims to integrate the fundamental sciences of the written word (paleography, codicology, epigraphy, history of the book, etc.) and other social and human sciences (linguistics, history, anthropology, etc.) into the digital and computational humanities. It will develop machine vision tools (for handwriting recognition and document analysis, for example) and tools for (semi)-automatic classification of symbols and texts, with a focus on pre-typographical and/or non-alphabetic cultures. It will also provide additional inquiry into written traditions of rare languages and writings, which are currently underrepresented at the University."@en ;
    dcterms:identifier "0cf58379-39c3-4e95-b7b1-cc9f7f11c7ba" ;
    dcterms:isPartOf <https://closingthegap.org/id/project/31ad93ff-ca97-4cf0-b30c-60685624e2c8> ;
