<https://closingthegap.org/id/project/1fb988de-a02c-42d9-951d-1d7de01b598c> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2807465/wismar.html> ;
