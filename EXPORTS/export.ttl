<https://closingthegap.org/id/project/85e367b3-1703-4ea5-95e0-7401b05580fe> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2925177/freiburg.html> ;
            schema:name "Freiburg" ] ;
    dcterms:created "2024-12-16"^^xsd:date ;
    dcterms:description "The following project is meant to improve softwares skills of Transkribus in modern Bulgarian. Transkribus is about to get enabled to read Bulgarian handwritten texts from the 1960s until today. Since the start of the project the number of Bulgarian words recognized by the current model reached up to 55.000. It is now able to recognise some whole sentences without making mistakes. The current error quote is calculated by about 6%. At the end it is planned to reach up to 100.000 Bulgarian words trained by Transkribus. The final model will be published on Transkribus."@en ;
    dcterms:identifier "85e367b3-1703-4ea5-95e0-7401b05580fe" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/bul> ;
