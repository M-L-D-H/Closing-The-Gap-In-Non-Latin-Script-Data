<https://closingthegap.org/id/project/f16b7aed-d8ad-4373-9b75-0a871ba8d920> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/3174530/lucca.html> ;
            schema:name "Lucca" ] ;
    dcterms:created "2025-03-01"^^xsd:date ;
    dcterms:description "The aim of SPACE is to explore in detail the neglected issue of the system of the sciences as instantiated in the earliest examples of philosophical encyclopaedias, those penned by the Arabophone Persian polymath Avicenna (Ibn Sīnā, d. 1037). SPACE will explore in detail the structure and format of three philosophical summae by Avicenna, written in different languages (Arabic and Persian), at different times in the master's career, with different aims and targets, and coming in very different sizes."@en ;
    dcterms:identifier "f16b7aed-d8ad-4373-9b75-0a871ba8d920" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
        <http://id.loc.gov/vocabulary/iso639-2/fas> ;
    dcterms:title "The System of Philosophy in Arabic: Charting the Encyclopaedias"@en ;
