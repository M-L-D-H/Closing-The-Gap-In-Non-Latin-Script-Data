            schema:name "Hamadan" ] ;
    dcterms:created "2022-06-16"^^xsd:date ;
    dcterms:description "This project is dedicated to the study of the syntax of Iranian languages. It will investigate selected Middle Iranian corpora, and unrelated contact languages, in order to reconstruct the genesis and historical development of Iranian syntax with focus on largely ignored OVX (object-verb-oblique) word order type. The project’s results will be made available on two platforms: The Word Order in Western Asia Corpus and The HamBam Corpus (see project websites)."@en ;
    dcterms:identifier "c1a2957b-0c24-46e6-9a67-381997525a87" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/fas> ;
