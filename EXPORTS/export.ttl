<https://closingthegap.org/id/project/9437f5a6-090b-4947-a2f9-841633739516> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/3117735/> ;
            schema:name "Madrid" ] ;
    dcterms:created "2024-11-28"^^xsd:date ;
    dcterms:description "The EPYW project aims to geographically visualize the dissemination of early printed Yemeni works, offering an interactive platform for exploring this literary heritage. Users can search the database by author, editor, and publication year, accessing detailed metadata that includes author names, editor names, publishers, and publishing dates. Additionally, the project features advanced place-based analytics, enabling users to analyze documented works geographically and sort data by individuals, years, or publishers, providing valuable insights into the historical and cultural landscape of Yemeni print culture."@en ;
    dcterms:identifier "9437f5a6-090b-4947-a2f9-841633739516" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Early Prints of Yemeni Works"@en ;
    schema:additionalProperty [ a schema:PropertyValue ;
