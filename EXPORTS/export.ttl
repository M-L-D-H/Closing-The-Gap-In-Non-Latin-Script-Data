<https://closingthegap.org/id/project/0fd7b9cd-fdae-441b-a6fd-a791d4583ce0> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2852458/potsdam.html> ;
            schema:name "Potsdam" ] ;
    dcterms:created "2021-11-12"^^xsd:date ;
    dcterms:description "Corpus Coranicum develops a catalogue of early Qur’anic manuscripts and texts of the Islamic scholarly tradition, which are all published online (open access) by using TEI standards. It offers not only transcriptions of the manuscripts in original languages and their German translations, but also images of originals, variant readings and commentaries explaining their literary, cultural and historical context. The project focuses on the systematic documentation of sources related to the Qur’an with the objective to reconstruct the development of the first Muslim community as the interaction between the Prophet and the first addressees in Mecca and Medina."@en ;
    dcterms:identifier "0fd7b9cd-fdae-441b-a6fd-a791d4583ce0" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara>,
