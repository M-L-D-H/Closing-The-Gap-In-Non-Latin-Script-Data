<https://closingthegap.org/id/project/9513964d-3509-462e-9d64-c47fd3922459> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/281184/jerusalem.html> ;
            schema:name "Jerusalem" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/2918632/goettingen.html> ;
            schema:name "Göttingen" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/294801/haifa.html> ;
            schema:name "Haifa" ],
        [ dcterms:isReferencedBy <https://www.geonames.org/293397/tel-aviv.html> ;
            schema:name "Tel Aviv" ] ;
    dcterms:created "2022-03-28"^^xsd:date ;
    dcterms:description "This project is dedicated to enhancing and standardizing the research on the Dead Sea Scrolls, famous manuscripts contacting over 1000 biblical and non-biblical text in Hebrew and Aramaic languages dating back to period between 3 c. BC and 2 AD. Next to the preparation of the pioneer Digital Scholarly Edition of Qumran Texts the main focus of the project lies on the creation of a standardized environment for collaborative production of Scrolls editions, advanced research tools and a robust dynamic interlinked database of texts, images and annotations."@en ;
