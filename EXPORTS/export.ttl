            schema:name "Jerusalem" ] ;
    dcterms:created "2021-11-08"^^xsd:date ;
    dcterms:description "The main objective of this project is the identification and cataloguing of Arabic and Judaeo-Arabic manuscripts related to Bible exegesis and translation, known as the Firkovitch Collection. The series contains approximately 2700 manuscripts dating back to the Golden Age of Arabic lands (between 9th and 13th centuries), which provide an extraordinary window to the intellectual and religious life of the Jewish communities living in those areas in that time. The metadata of the manuscripts will be made accessible for further research."@en ;
    dcterms:identifier "ce6e74fb-c872-4ab4-a6f2-908232d0099a" ;
