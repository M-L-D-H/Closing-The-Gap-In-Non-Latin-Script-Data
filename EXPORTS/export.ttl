            schema:name "Amsterdam" ] ;
    dcterms:created "2023-11-02"^^xsd:date ;
    dcterms:description "The project aims to establish an online accessible digital platform where former and current residents of the Iraqi city of Mosul can contribute their personal and individual memories of their hometown. These memories can be inserted in the form of stories, images, and audio recordings, all placed on a digital and visually appealing map of Mosul and its surroundings (prior to 2014). After editorial processing and approval by a dedicated editorial team, these contributions will be accessible worldwide."@en ;
    dcterms:identifier "aec92ee9-7c8a-49ce-8491-46667fc75505" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/ara> ;
    dcterms:title "Memory Spaces: Mapping Oral History in Mosul"@en ;
