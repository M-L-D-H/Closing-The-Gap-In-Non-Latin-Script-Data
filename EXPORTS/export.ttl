<https://closingthegap.org/id/project/c1a2957b-0c24-46e6-9a67-381997525a87> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2952984/bamberg.html> ;
