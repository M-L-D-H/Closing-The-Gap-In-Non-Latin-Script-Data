<https://closingthegap.org/id/project/b37c6bd1-90d3-4718-ab58-fb1d60873186> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2952984/bamberg.html> ;
            schema:name "Bamberg" ] ;
    dcterms:created "2022-06-16"^^xsd:date ;
    dcterms:description "Multi-CAST is a collection of annotated texts from a typologically diverse selection of 15 languages including endangered ones. The corpus is freely accessible via an online platform which provides multiple levels of parallel annotations, time-aligned with audio recordings, chiefly monologic, natural narrative texts from 15 languages, encompassing roughly 25,000 clause units available in multiple file formats, including as EAF files for the linguistic annotation software ELAN, as XML and TSV files, and via the multicastR package for R."@en ;
    dcterms:identifier "b37c6bd1-90d3-4718-ab58-fb1d60873186" ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-2/atz>,
