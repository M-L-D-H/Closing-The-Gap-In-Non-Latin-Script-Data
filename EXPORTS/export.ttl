<https://closingthegap.org/id/project/aec92ee9-7c8a-49ce-8491-46667fc75505> a schema:ResearchProject ;
    dcterms:Location [ dcterms:isReferencedBy <https://www.geonames.org/2950159/berlin.html> ;
